{
  "respectGitignore": true,
  "cleanupPeriodDays": 30,
  "includeGitInstructions": false,
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "Write(*)",
      "Edit(*)",
      "mcp__claude_ai_Context7__resolve-library-id",
      "mcp__claude_ai_Microsoft_Learn__*",
      "mcp__plugin_context-mode_context-mode__*",
      "mcp__plugin_trueline-mcp_mcp__*",
      "mcp__plugin_trueline-mcp_trueline__*"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(sudo *)",
      "Bash(chmod -R 777 *)",
      "Bash(> *)",
      "Read(.env)",
      "Read(**/.env)",
      "Read(**/*credentials*)",
      "Read(**/*secret*.env)",
      "Read(**/*secret*.json)",
      "Read(**/*secret*.yaml)",
      "Read(**/*secret*.yml)",
      "Read(**/*secret*.key)",
      "Read(**/*secret*.pem)"
    ],
    "defaultMode": "acceptEdits"
  },
  "model": "opus",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "terminal-notifier -title 'Claude Code' -message 'Claude Code needs your attention' -sound Ping"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"/Users/rjk/.claude/hooks/context-mode-cache-heal.mjs\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/rjk/.claude/hooks/inject-delegate-directive.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit|mcp__.*trueline_edit",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/rjk/.claude/hooks/enforce-subagent.sh"
          }
        ]
      },
      {
        "matcher": "Read|Grep|Glob|mcp__.*trueline_(read|search|outline)",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/rjk/.claude/hooks/advise-explore.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/rjk/.claude/hooks/commit-attribution-guard"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/rjk/.claude/hooks/worktree-location-guard"
          }
        ]
      },
      {
        "matcher": "EnterWorktree",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/rjk/.claude/hooks/worktree-location-guard"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/rjk/.claude/hooks/tmp-path-guard"
          },
          {
            "type": "command",
            "command": "/Users/rjk/.claude/hooks/plan-guard"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/rjk/.claude/hooks/agent-input-guard"
          }
        ]
      }
    ],
    "PostToolUse": [],
    "Stop": [],
    "SessionEnd": []
  },
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "claude-md-management@claude-plugins-official": false,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": false,
    "commit-commands@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": false,
    "hookify@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": false,
    "plugin-dev@claude-plugins-official": false,
    "pr-review-toolkit@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": false,
    "superpowers@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "ast-grep@ast-grep-marketplace": true,
    "csharp-lsp@claude-plugins-official": true,
    "agent-orchestration@claude-code-workflows": false,
    "agent-teams@claude-code-workflows": false,
    "application-performance@claude-code-workflows": false,
    "backend-api-security@claude-code-workflows": false,
    "backend-development@claude-code-workflows": true,
    "cicd-automation@claude-code-workflows": false,
    "code-refactoring@claude-code-workflows": true,
    "codebase-cleanup@claude-code-workflows": false,
    "comprehensive-review@claude-code-workflows": false,
    "conductor@claude-code-workflows": false,
    "context-management@claude-code-workflows": false,
    "database-design@claude-code-workflows": false,
    "database-migrations@claude-code-workflows": false,
    "debugging-toolkit@claude-code-workflows": true,
    "developer-essentials@claude-code-workflows": true,
    "dotnet-contribution@claude-code-workflows": true,
    "error-debugging@claude-code-workflows": false,
    "error-diagnostics@claude-code-workflows": false,
    "frontend-mobile-security@claude-code-workflows": false,
    "full-stack-orchestration@claude-code-workflows": false,
    "git-pr-workflows@claude-code-workflows": false,
    "performance-testing-review@claude-code-workflows": false,
    "reverse-engineering@claude-code-workflows": false,
    "security-scanning@claude-code-workflows": true,
    "shell-scripting@claude-code-workflows": true,
    "systems-programming@claude-code-workflows": true,
    "tdd-workflows@claude-code-workflows": false,
    "caveman@caveman": false,
    "javascript-typescript@claude-code-workflows": true,
    "context-mode@context-mode": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "ast-grep-marketplace": {
      "source": {
        "source": "github",
        "repo": "ast-grep/agent-skill"
      }
    },
    "rjk-local": {
      "source": {
        "source": "directory",
        "path": "/Users/rjk/SynologyDrive/Drive/dotfiles/dot-claude/plugins/local-marketplace"
      }
    },
    "claude-code-workflows": {
      "source": {
        "source": "github",
        "repo": "wshobson/agents"
      }
    },
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "context-mode": {
      "source": {
        "source": "github",
        "repo": "mksglu/context-mode"
      }
    }
  },
  "effortLevel": "xhigh",
  "showClearContextOnPlanAccept": true,
  "tui": "fullscreen",
  "autoDreamEnabled": true,
  "theme": "light-daltonized",
  "skipAutoPermissionPrompt": true,
  "useAutoModeDuringPlan": true
}
