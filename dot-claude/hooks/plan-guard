#!/bin/sh
set -eu

payload=$(cat)
tool="" path=""  # set by eval below
eval "$(printf '%s' "$payload" | jq -r '"tool=" + (.tool_name // "" | @sh) + " path=" + (.tool_input.file_path // "" | @sh)')"

case "$tool" in
    Write|Edit) ;;
    *) exit 0 ;;
esac

case "$path" in
    "$HOME"/.claude/plans/*.md) ;;
    *) exit 0 ;;
esac

# For Write, check the payload content (file doesn't exist yet); for Edit, check the existing file
if [ "$tool" = "Write" ]; then
    check=$(printf '%s' "$payload" | jq -r '.tool_input.content // ""')
elif [ -f "$path" ]; then
    check=$(cat "$path")
else
    exit 0
fi

missing=""
printf '%s' "$check" | grep -qF '## Implementation via sub-agents' || missing="$missing sub-agents"

[ -z "$missing" ] && exit 0

printf 'plan-guard: %s missing required section(s):%s. Add them exactly as specified in CLAUDE.md -> "Plan file requirements".\n' \
    "$path" "$missing" >&2
exit 2
